# Cloudflare Pages cache policy (https://developers.cloudflare.com/pages/configuration/headers/).
# Copied verbatim into dist/ by Vite, read by Pages on preview and production.
#
# CF *combines* (does not override) headers from every matching rule, so a `/*`
# catch-all would append `no-cache` onto the asset rule's value and defeat
# `immutable`. We therefore enumerate the no-cache paths (by SPA route section)
# so the fingerprinted assets match only their own rule. Add a section here when
# a new top-level route is introduced.

# Fingerprinted build assets never change — cache forever.
/_app/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Everything else is the SPA shell (index.html), served for every app route:
# no-cache so a deploy is picked up immediately (cheap 304 via ETag). Listed by
# section; the bare and splat forms cover the index and its sub-routes.
/
  Cache-Control: no-cache

/a8
  Cache-Control: no-cache

/a8/*
  Cache-Control: no-cache

/labs
  Cache-Control: no-cache

/labs/*
  Cache-Control: no-cache

/legal/*
  Cache-Control: no-cache

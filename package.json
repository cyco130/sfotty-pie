{
  "name": "sfotty-pie-workspace-root",
  "private": "true",
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./packages/*\" --filter \"!@sfotty-pie/template-*\" run dev",
    "build": "pnpm -r --filter \"./packages/*\" --filter \"!@sfotty-pie/template-*\" run build",
    "prepare": "husky",
    "precommit": "lint-staged",
    "format": "prettier --write .",
    "conformance": "pnpm -r --filter \"!@sfotty-pie/template-*\" --stream run conformance",
    "test": "pnpm run /^test:/",
    "test:packages": "pnpm -r --filter \"!@sfotty-pie/template-*\" --stream run test",
    "test:format": "prettier --check ."
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  }
}

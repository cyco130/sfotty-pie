{
  "name": "@sfotty-pie/a8",
  "version": "0.0.0",
  "description": "A (for now headless) Atari 8-bit emulator.",
  "keywords": [
    "atari",
    "atari-8-bit",
    "atari-800",
    "6502",
    "emulator",
    "emulation",
    "retro"
  ],
  "license": "MIT",
  "repository": "github:cyco130/sfotty-pie",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json",
    "test:lint": "eslint . --max-warnings 0",
    "test:package": "publint",
    "boot": "node src/boot.ts"
  },
  "dependencies": {
    "@sfotty-pie/sfotty": "workspace:*"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^9.0.1",
    "@types/node": "^22.19.19",
    "eslint": "^10.4.1",
    "publint": "^0.3.21",
    "tsdown": "0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "22 || 24 || 25 || 26"
  }
}

{
  "name": "@sfotty-pie/a8",
  "version": "0.2.1",
  "description": "A headless Atari 8-bit emulator — bring your own display, audio, and input.",
  "keywords": [
    "atari",
    "atari-8-bit",
    "atari-800",
    "6502",
    "emulator",
    "emulation",
    "retro"
  ],
  "license": "MIT",
  "repository": "github:cyco130/sfotty-pie",
  "files": [
    "dist",
    "atari-src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "pnpm build:loader && tsdown --clean",
    "build:loader": "node src/build-loader.ts",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json",
    "test:lint": "eslint . --max-warnings 0",
    "test:package": "publint",
    "boot": "node src/boot.ts",
    "acid800-tests": "node src/acid800-tests.ts",
    "ci": "pnpm acid800-tests && pnpm acid800-tests --pal"
  },
  "dependencies": {
    "@sfotty-pie/sfotty": "workspace:*",
    "crc-32": "^1.2.2"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^9.0.1",
    "@sfotty-pie/spasm": "workspace:*",
    "@types/node": "^22.19.19",
    "eslint": "^10.4.1",
    "publint": "^0.3.21",
    "tsdown": "0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "22 || 24 || 25 || 26"
  }
}

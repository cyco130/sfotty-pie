{
  "name": "@sfotty-pie/cli",
  "version": "0.2.1",
  "description": "An emulator for a hypothetical 6502-based system.",
  "keywords": [
    "6502",
    "emulator",
    "emulation",
    "cli",
    "virtual-machine",
    "retro"
  ],
  "license": "MIT",
  "repository": "github:cyco130/sfotty-pie",
  "files": [
    "dist",
    "samples",
    "src/samples"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "sfotty": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json",
    "test:lint": "eslint . --max-warnings 0",
    "test:package": "publint",
    "build:samples": "node src/build-samples.ts"
  },
  "dependencies": {
    "@sfotty-pie/sfotty": "workspace:*"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^9.0.2",
    "@sfotty-pie/spasm": "workspace:*",
    "@types/node": "^22.20.0",
    "eslint": "^10.5.0",
    "publint": "^0.3.21",
    "tsdown": "0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "22 || 24 || 25 || 26"
  }
}

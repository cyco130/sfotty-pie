{
  "name": "@sfotty-pie/sfotty",
  "version": "0.2.1",
  "description": "Cycle-exact 6502 emulator.",
  "keywords": [
    "6502",
    "nmos-6502",
    "mos-6502",
    "2a03",
    "cpu",
    "emulator",
    "emulation",
    "cycle-accurate"
  ],
  "license": "MIT",
  "repository": "github:cyco130/sfotty-pie",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json",
    "test:lint": "eslint . --max-warnings 0",
    "test:package": "publint",
    "ci": "pnpm single-step-tests",
    "single-step-tests": "node src/single-step-tests.ts",
    "generate:instructions": "node src/generate-instructions.ts",
    "generate:steps": "node src/generate-steps.ts"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^9.0.1",
    "@types/node": "^22.19.19",
    "eslint": "^10.4.1",
    "publint": "^0.3.21",
    "tsdown": "0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "22 || 24 || 25 || 26"
  }
}

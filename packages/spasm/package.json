{
  "name": "@sfotty-pie/spasm",
  "version": "0.0.0",
  "description": "A work-in-progress 6502 cross-assembler/linker.",
  "keywords": [
    "6502",
    "assembler",
    "6502-assembler",
    "macro-assembler",
    "cross-assembler",
    "nmos-6502",
    "linker"
  ],
  "license": "MIT",
  "repository": "github:cyco130/sfotty-pie",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "spasm": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "tsdown --watch",
    "prepack": "pnpm build",
    "test": "pnpm run /^test:/",
    "test:unit": "vitest run",
    "test:typecheck": "tsc -p tsconfig.json",
    "test:lint": "eslint . --max-warnings 0",
    "test:package": "publint",
    "generate:opcodes": "node src/generate-opcodes.ts"
  },
  "devDependencies": {
    "@cyco130/eslint-config": "^9.0.1",
    "@types/node": "^22.19.19",
    "eslint": "^10.4.1",
    "publint": "^0.3.21",
    "tsdown": "0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "22 || 24 || 25 || 26"
  }
}
